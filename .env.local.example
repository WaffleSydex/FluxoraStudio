# Fluxora Studio — environment variables
# Copy this file to ".env.local" and fill in the values.

# ── Supabase ──────────────────────────────────────────────
# Supabase Dashboard -> Project Settings -> API
# Public (safe in the browser) — used to READ content for the public site.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key — SERVER ONLY. Powers admin writes + uploads.
# NEVER expose this or prefix it with NEXT_PUBLIC_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin login (the /admin backend) ─────────────────────
# You choose these. This is how you log into /admin.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=choose-a-strong-password
# Long random string used to sign the admin session cookie.
# Generate one, e.g.:  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SESSION_SECRET=replace-with-a-long-random-string

# ── Contact form email (Resend) ──────────────────────────
# https://resend.com/api-keys
RESEND_API_KEY=your-resend-api-key
# Where enquiries are delivered:
CONTACT_TO_EMAIL=info@fluxorastudio.com
# Verified sender. Until fluxorastudio.com is verified in Resend you can use
# "Fluxora Studio <onboarding@resend.dev>". After verifying the domain switch to
# something like "Fluxora Studio <noreply@fluxorastudio.com>".
CONTACT_FROM_EMAIL=Fluxora Studio <onboarding@resend.dev>

# ── Cloudflare Turnstile (spam protection) ───────────────
# https://dash.cloudflare.com -> Turnstile
# Site key is public; secret key is SERVER ONLY.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAADn16_5KwKyWuIQc
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ── Site ─────────────────────────────────────────────────
# Public site URL for SEO / Open Graph. No trailing slash.
NEXT_PUBLIC_SITE_URL=https://fluxorastudio.com
